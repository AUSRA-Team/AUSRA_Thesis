\@writefile{lof}{\contentsline {figure}{\numberline {6.2}{\ignorespaces The A--B--C range limitation. Node A reaches B and B reaches C, but A and C are out of direct WiFi range. A direct A--C path would require B to forward traffic on their behalf --- multi-hop routing that ad-hoc WiFi does not provide on its own.\relax }}{121}{figure.caption.184}\protected@file@percent }
\newlabel{fig:abc}{{6.2}{121}{The A--B--C range limitation. Node A reaches B and B reaches C, but A and C are out of direct WiFi range. A direct A--C path would require B to forward traffic on their behalf --- multi-hop routing that ad-hoc WiFi does not provide on its own.\relax }{figure.caption.184}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6.3}{\ignorespaces The three-layer stack a true robot-to-robot mesh would require. The middle layer, \texttt  {batman-adv}, is the piece that was identified as necessary but deliberately not implemented; without it, Zenoh alone cannot route across the A--B--C gap.\relax }}{121}{figure.caption.185}\protected@file@percent }
\newlabel{fig:batman_stack}{{6.3}{121}{The three-layer stack a true robot-to-robot mesh would require. The middle layer, \texttt {batman-adv}, is the piece that was identified as necessary but deliberately not implemented; without it, Zenoh alone cannot route across the A--B--C gap.\relax }{figure.caption.185}{}}
